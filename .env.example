# ============================================
# Kotak Trading Application - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file with real credentials to version control

# ============================================
# Django Settings
# ============================================
# Generate a secure secret key using:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secure-secret-key-here

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# Database Settings (PostgreSQL)
# ============================================
DB_NAME=trading_db
DB_USER=trading_user
DB_PASSWORD=your-secure-db-password
DB_HOST=db
DB_PORT=5432

# ============================================
# Redis Settings
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# Encryption Settings
# ============================================
# Generate encryption key using:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# ============================================
# Kotak Neo API Settings
# ============================================
# Get these from Kotak Neo API developer portal
KOTAK_CONSUMER_KEY=your-kotak-consumer-key
KOTAK_CONSUMER_SECRET=your-kotak-consumer-secret
KOTAK_REDIRECT_URI=http://localhost:8000/api/auth/kotak/callback
KOTAK_TOTP_ISSUER=KotakSecurities

# ============================================
# Risk Management Settings (Optional)
# ============================================
MAX_LOSS_PERCENTAGE=2.0
MAX_POSITION_SIZE_PERCENTAGE=10.0
ENABLE_MARGIN_CHECK=True
ENABLE_POSITION_LIMITS=True

# ============================================
# Email Settings (Optional - for notifications)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# ============================================
# Logging Settings
# ============================================
LOG_LEVEL=INFO
